# 硅基流动（复制为 .env 后填写；勿提交 .env）
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL_OCR=deepseek-ai/DeepSeek-OCR
# 若控制台为 Qwen-Max，请改为控制台中的精确 model id
SILICONFLOW_MODEL_QWEN=Qwen/Qwen3-235B-A22B-Instruct-2507
# OCR 输出长度上限（须 ≤ 模型 max_seq_len，硅基 DeepSeek-OCR 多为 8192；默认 4096）
# SILICONFLOW_OCR_MAX_TOKENS=4096

# 为 true 时强制 MOCK（不调 SiliconFlow）
USE_MOCK=false
# 为 true 时仅 OCR，不调 Qwen（structured 为 null）
SILICONFLOW_SKIP_QWEN=false

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# OCR_TIMEOUT_SEC=300
# LLM_TIMEOUT_SEC=120
# MAX_MARKDOWN_CHARS_FOR_QWEN=120000
# MAX_UPLOAD_BYTES=20971520

# 多页解析 Markdown 存储目录（默认 pdf_intel_backend/data/documents）
# DOCUMENTS_STORAGE_DIR=
# MAX_PDF_PAGES_PAGED=200
# DOC_CHAT_MAX_CONTEXT_CHARS=80000
# DOC_CHAT_MAX_TOKENS=2048
# 对话前「大模型选页」：摘录条长度、参与路由的最大页数、目录总字数上限、最多选出页数
# DOC_PAGE_ROUTER_SNIPPET_CHARS=320
# DOC_ROUTER_PREFILTER_PAGES=96
# DOC_ROUTER_CATALOG_MAX_CHARS=90000
# DOC_PAGE_ROUTER_MAX_PICK=28
# DOC_PAGE_ROUTER_MAX_TOKENS=512
# DOC_PAGE_ROUTER_TIMEOUT_SEC=90
# SILICONFLOW_MODEL_ROUTER=   （空则与 Qwen 模型相同）
# JOBS_STORAGE_DIR=
