# =========================
# 飞书物资管理系统环境配置
# =========================
# 说明：
# 1) 本文件中的变量会覆盖 config/app_config.toml 同名配置
# 2) 列表类型使用英文逗号分隔，例如: ou_a,ou_b
# 3) 布尔值支持: true/false

# -------------------------
# 应用基础配置
# -------------------------
APP_NAME=飞书物资管理系统
APP_DB_PATH=data/materials.db
APP_TIMEZONE=Asia/Shanghai
APP_HOME_URL=https://corp-mms.streamlit.app/
# 是否启用借用审批流（true 时：用户提交后为待审批，管理员通过后才出库）
APP_REQUIRE_BORROW_APPROVAL=true

# -------------------------
# 飞书开放平台配置
# -------------------------
FEISHU_APP_ID=cli_a9496c039df89cba
FEISHU_APP_SECRET=4DfUqlRREtEO2C5shJhI6dp2TrCGcxDV
# 通常留空：系统会在运行时用 FEISHU_APP_ID/FEISHU_APP_SECRET 自动换取 token
# 仅在特殊场景（网络受限或手动调试）下再手动填写
FEISHU_TENANT_ACCESS_TOKEN=
FEISHU_BASE_URL=https://open.feishu.cn/open-apis
FEISHU_REDIRECT_URI=https://corp-mms.streamlit.app/

# -------------------------
# 权限配置（管理员）
# -------------------------
# open_id 白名单（推荐主配置）
RBAC_ADMIN_OPEN_IDS=ou_0ea988304c29c0f73d6d360ef28d361e
# 邮箱白名单（可选，可与 open_id 并用）
RBAC_ADMIN_EMAILS=18681575528@163.com

# -------------------------
# 通知配置
# -------------------------
# 是否启用飞书通知发送（false 时仅记录通知日志，不实际发送）
NOTIFY_ENABLE=false
# 到期前 N 天开始提醒
NOTIFY_DAYS_BEFORE_DUE=3
# 扫描逾期/到期任务的执行间隔（小时）
NOTIFY_OVERDUE_EVERY_HOURS=24
# 发送失败最大重试次数
NOTIFY_RETRY_LIMIT=3
# 逾期时抄送管理员 open_id（逗号分隔）
NOTIFY_ADMIN_CC_OPEN_IDS=
# 是否使用租户内已创建的模板卡片（true 时需要你在代码中替换 template_id）
NOTIFY_USE_TEMPLATE_CARD=false

# -------------------------
# 通知文案模板
# -------------------------
NOTIFY_DUE_TEMPLATE=【到期提醒】你借用的物资即将到期，请尽快归还。
NOTIFY_OVERDUE_TEMPLATE=【逾期提醒】你借用的物资已逾期，请立即归还并在系统确认。
NOTIFY_MANUAL_TEMPLATE=【催还提醒】管理员发起了催还，请尽快处理该借用单。
